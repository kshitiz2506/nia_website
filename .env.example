# Copy this file to .env and fill in real values. Never commit .env.

# --- Server (server/index.js) ---
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# --- Email confirmations (server/lib/resendEmail.js) ---
# https://resend.com — API key and a verified "from" sender/domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL="NIA Aesthetics <noreply@yourdomain.com>"
SITE_NAME=NIA — Next India Institute of Aesthetics

# --- Google Sheets logging via Apps Script webhook (server/lib/googleSheets.js) ---
# See server/google-apps-script/contact-form.gs for setup steps.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_SECRET=

# --- Frontend (Vite) ---
# Optional in dev — requests default to /api via the Vite proxy.
# Required in production — point this at your deployed API origin.
VITE_API_URL=/api
# Canonical site URL used for SEO metadata and sitemap generation.
VITE_SITE_URL=https://www.nianextindia.com
